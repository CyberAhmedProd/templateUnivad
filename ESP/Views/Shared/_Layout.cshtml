<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ESP</title>
    <!-- Bootstrap 3 -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap.min.css" />
    <style>
        /* ── Microsoft Docs color palette ── */
        :root {
            --ms-blue:       #0078d4;
            --ms-blue-dark:  #005a9e;
            --ms-blue-light: #deecf9;
            --ms-bg:         #f3f2f1;
            --ms-sidebar-bg: #faf9f8;
            --ms-border:     #edebe9;
            --ms-text:       #323130;
            --ms-text-muted: #605e5c;
            --ms-topbar:     #0078d4;
            --ms-green:      #107c10;
            --ms-red:        #d13438;
            --ms-orange:     #ca5010;
        }

        * { box-sizing: border-box; }
        body { background: var(--ms-bg); color: var(--ms-text); font-family: "Segoe UI", system-ui, sans-serif; font-size: 14px; padding: 0; margin: 0; }

        /* Top bar */
        .top-bar { background: var(--ms-topbar); color: #fff; padding: 0 16px; height: 48px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 2px 4px rgba(0,0,0,.14); }
        .top-bar .brand { font-size: 15px; font-weight: 600; letter-spacing: .3px; }
        .top-bar .user-info { font-size: 13px; opacity: .9; }
        .top-bar .user-info .glyphicon { margin-right: 5px; }

        /* Sidebar */
        .sidebar { min-height: calc(100vh - 48px); background: var(--ms-sidebar-bg); border-right: 1px solid var(--ms-border); padding-top: 8px; width: 220px; flex-shrink: 0; }
        .sidebar ul { padding: 0; list-style: none; margin: 0; }
        .sidebar ul li a { display: flex; align-items: center; padding: 9px 16px; color: var(--ms-text); text-decoration: none; font-size: 13.5px; border-left: 3px solid transparent; transition: background .1s; }
        .sidebar ul li a .glyphicon { margin-right: 9px; color: var(--ms-text-muted); font-size: 13px; }
        .sidebar ul li a:hover { background: var(--ms-blue-light); color: var(--ms-blue-dark); border-left-color: var(--ms-blue-light); }
        .sidebar ul li.active > a { background: var(--ms-blue-light); color: var(--ms-blue); border-left-color: var(--ms-blue); font-weight: 600; }
        .sidebar ul li.active > a .glyphicon { color: var(--ms-blue); }
        .sidebar .nav-header { padding: 14px 16px 4px; color: var(--ms-text-muted); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .8px; }

        /* Layout */
        .app-body { display: flex; min-height: calc(100vh - 48px); }
        .main-content { flex: 1; padding: 24px 28px; overflow-x: auto; }

        /* Page header */
        .page-header { margin-top: 0; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid var(--ms-border); }
        .page-header h3 { font-size: 20px; font-weight: 600; color: var(--ms-text); margin: 0; }

        /* Breadcrumb */
        .breadcrumb { background: transparent; padding: 0 0 12px; margin-bottom: 16px; font-size: 13px; }
        .breadcrumb > li + li::before { color: var(--ms-text-muted); }
        .breadcrumb a { color: var(--ms-blue); }

        /* Panel */
        .panel { border: 1px solid var(--ms-border); border-radius: 4px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
        .panel-default > .panel-heading { background: #fff; border-bottom: 1px solid var(--ms-border); color: var(--ms-text); font-weight: 600; }

        /* Buttons */
        .btn-primary { background-color: var(--ms-blue); border-color: var(--ms-blue); }
        .btn-primary:hover, .btn-primary:focus { background-color: var(--ms-blue-dark); border-color: var(--ms-blue-dark); }
        .btn-success { background-color: var(--ms-green); border-color: var(--ms-green); }
        .btn-success:hover { background-color: #0b6a0b; border-color: #0b6a0b; }
        .btn-danger { background-color: var(--ms-red); border-color: var(--ms-red); }
        .btn-danger:hover { background-color: #b52d30; border-color: #b52d30; }
        .btn-warning { background-color: var(--ms-orange); border-color: var(--ms-orange); color: #fff; }
        .btn-warning:hover { background-color: #a94010; border-color: #a94010; color: #fff; }
        .btn-info { background-color: #0078d4; border-color: #0078d4; }
        .btn-default { background: #fff; border-color: #8a8886; color: var(--ms-text); }
        .btn-default:hover { background: var(--ms-bg); }

        /* Tables */
        .table > thead > tr > th { background: var(--ms-bg); color: var(--ms-text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; border-bottom: 2px solid var(--ms-border); }
        .table > tbody > tr:hover > td { background: var(--ms-blue-light); }
        .table-bordered { border-color: var(--ms-border); }
        .table-bordered > thead > tr > th, .table-bordered > tbody > tr > td { border-color: var(--ms-border); }
        .table-actions button, .table-actions a { margin: 0 2px; }

        /* Tabs */
        .nav-tabs { border-bottom: 2px solid var(--ms-blue); }
        .nav-tabs > li > a { color: var(--ms-text-muted); border: none; border-bottom: 2px solid transparent; margin-bottom: -2px; padding: 8px 16px; font-size: 13.5px; }
        .nav-tabs > li > a:hover { background: var(--ms-blue-light); color: var(--ms-blue); border-color: transparent; }
        .nav-tabs > li.active > a, .nav-tabs > li.active > a:focus, .nav-tabs > li.active > a:hover { color: var(--ms-blue); border: none; border-bottom: 2px solid var(--ms-blue); font-weight: 600; background: transparent; }
        .tab-content { background: #fff; border: 1px solid var(--ms-border); border-top: none; padding: 16px; border-radius: 0 0 4px 4px; }

        /* Labels */
        .label-success { background-color: var(--ms-green); }
        .label-default { background-color: var(--ms-text-muted); }
        .label-primary { background-color: var(--ms-blue); }

        /* Modals */
        .modal-header { background: var(--ms-blue); color: #fff; border-radius: 4px 4px 0 0; padding: 12px 16px; }
        .modal-header .modal-title { font-size: 15px; font-weight: 600; }
        .modal-header .close { color: #fff; opacity: .8; font-size: 20px; }
        .modal-header .close:hover { opacity: 1; }
        .modal-content { border: none; border-radius: 4px; box-shadow: 0 8px 32px rgba(0,0,0,.18); }
        .modal-footer { background: var(--ms-bg); border-top: 1px solid var(--ms-border); border-radius: 0 0 4px 4px; }

        /* Forms */
        .form-control { border-color: #8a8886; border-radius: 2px; font-size: 14px; }
        .form-control:focus { border-color: var(--ms-blue); box-shadow: 0 0 0 1px var(--ms-blue); }
        label { font-weight: 600; font-size: 13px; color: var(--ms-text); }

        /* DataTables overrides */
        .dataTables_wrapper .dataTables_filter input { border-color: #8a8886; border-radius: 2px; }
        .dataTables_wrapper .dataTables_length select { border-color: #8a8886; border-radius: 2px; }
        table.dataTable thead th { background: var(--ms-bg); }
        .paginate_button.current, .paginate_button.current:hover { background: var(--ms-blue) !important; border-color: var(--ms-blue) !important; color: #fff !important; border-radius: 2px; }
        .paginate_button:hover { background: var(--ms-blue-light) !important; color: var(--ms-blue) !important; border-color: var(--ms-border) !important; }
    </style>
</head>
<body>
    <!-- Top bar -->
    <div class="top-bar">
        <span class="brand">
            <span class="glyphicon glyphicon-education" style="margin-right:8px"></span>
            Ecole Nationale d'Ingénieurs de Monastir — ESP
        </span>
        <span class="user-info">
            <span class="glyphicon glyphicon-user"></span> Administrateur
        </span>
    </div>

    <div class="app-body">
        <!-- Sidebar -->
        <div class="sidebar">
            <ul>
                <li class="nav-header">Planification</li>
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Session" ? "active" : "")">
                    <a href="/Session"><span class="glyphicon glyphicon-calendar"></span> Sessions</a>
                </li>
                <li class="nav-header">Paramètres</li>
                <li>
                    <a href="#"><span class="glyphicon glyphicon-cog"></span> Configuration</a>
                </li>
            </ul>
        </div>

        <!-- Main content -->
        <div class="main-content">
            @RenderBody()
        </div>
    </div>

    <!-- jQuery 3 -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap 3 JS -->
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
