    // ===== SUPPRESSION GÉNÉRIQUE =====
    function delItem(type, id, label) {
        var urls = {
            seance: '/SessionSeance/Delete', filiere: '/SessionFiliere/Delete',
            niveau: '/SessionNiveau/Delete', jour: '/SessionJour/Delete',
            centre: '/SessionCentre/Delete', niveaucentre: '/SessionNiveauCentre/Delete',
            epreuve: '/SessionEpreuve/Delete', credits: '/SessionCredits/Delete'
        };
        var reloads = {
            seance: loadSeances, filiere: function(){ loadFilieres(); loadNiveaux(); },
            niveau: loadNiveaux, jour: loadJournees,
            centre: function(){ loadCentres(); loadNiveauCentre(); }, niveaucentre: loadNiveauCentre,
            epreuve: function(){ loadEpreuves(); loadCredits(); }, credits: loadCredits
        };
        $('#delMsg').text('Supprimer "' + label + '" ?');
        $('#btnDel').off('click').on('click', function () {
            $.post(urls[type] + '?id=' + id, function () { $('#modalDel').modal('hide'); reloads[type](); });
        });
        $('#modalDel').modal('show');
    }

    function editSession() { window.location.href = '/Session?edit=' + sessionId; }
