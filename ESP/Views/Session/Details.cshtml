@model ESP.Models.Session
@{
    ViewData["Title"] = "Détails de session";
}

<ol class="breadcrumb">
    <li><a href="/Session">Planification des examens</a></li>
    <li class="active">Détails de session : @Model.Annee - @Model.Designation</li>
</ol>

<div class="panel panel-default">
    <div class="panel-body">
        <div class="row">
            <div class="col-md-1 text-center">
                <span class="glyphicon glyphicon-calendar" style="font-size:60px;color:#2c3e50"></span>
            </div>
            <div class="col-md-10">
                <div class="row">
                    <div class="col-md-4"><strong>Désignation :</strong> @Model.Designation</div>
                    <div class="col-md-4"><strong>Année :</strong> @Model.Annee</div>
                    <div class="col-md-4 text-right">
                        <button class="btn btn-warning btn-sm" onclick="editSession()">
                            <span class="glyphicon glyphicon-pencil"></span> Modifier
                        </button>
                    </div>
                </div>
                <div class="row" style="margin-top:8px">
                    <div class="col-md-4"><strong>Date de début :</strong> @Model.DateDebut.ToString("dd/MM/yyyy")</div>
                    <div class="col-md-4"><strong>Date de fin :</strong> @Model.DateFin.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="row" style="margin-top:8px">
                    <div class="col-md-4"><strong>Type de Session :</strong> @Model.Type</div>
                    <div class="col-md-4"><strong>Période :</strong> @Model.Periode</div>
                </div>
                <div class="row" style="margin-top:8px">
                    <div class="col-md-4"><strong>Unité :</strong> @Model.Unite</div>
                    <div class="col-md-4"><strong>Utiliser les Groupes :</strong> @(Model.UseGroupe == 1 ? "Oui" : "Non")</div>
                </div>
                <div class="row" style="margin-top:8px">
                    <div class="col-md-4"><strong>État :</strong>
                        <span class="label @(Model.Etat == "En Cours" ? "label-success" : "label-default")">@Model.Etat</span>
                    </div>
                    <div class="col-md-8"><strong>Observations :</strong> @Model.Observations</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Onglets -->
<ul class="nav nav-tabs" id="sessionTabs">
    <li class="active"><a href="#tab-seances" data-toggle="tab">Séances</a></li>
    <li><a href="#tab-filieres" data-toggle="tab">Filières</a></li>
    <li><a href="#tab-niveaux" data-toggle="tab">Niveaux</a></li>
    <li><a href="#tab-journees" data-toggle="tab">Journées</a></li>
    <li><a href="#tab-centres" data-toggle="tab">Centres</a></li>
    <li><a href="#tab-niveaucentre" data-toggle="tab">Niveaux-Centres</a></li>
    <li><a href="#tab-epreuves" data-toggle="tab">Épreuves</a></li>
    <li><a href="#tab-credits" data-toggle="tab">Crédits</a></li>
</ul>

<div class="tab-content" style="border:1px solid #ddd;border-top:none;padding:15px">

    <!-- Séances -->
    <div class="tab-pane active" id="tab-seances">
        <div class="clearfix" style="margin-bottom:10px">
            <div class="pull-left">
                <span class="glyphicon glyphicon-info-sign text-info"></span>
                <span id="nbSeances">0</span> séance(s)
            </div>
            <div class="pull-right">
                <button class="btn btn-default btn-sm"><span class="glyphicon glyphicon-import"></span> Importer par session</button>
                <button class="btn btn-success btn-sm" onclick="openSeanceModal(0)">
                    <span class="glyphicon glyphicon-plus"></span>
                </button>
            </div>
        </div>
        <table id="tblSeances" class="table table-striped table-bordered table-hover">
            <thead>
                <tr>
                    <th>Désignation</th>
                    <th>Désignation abrégée</th>
                    <th>Heure de début</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="bodySeances"></tbody>
        </table>
    </div>

    <!-- Filières -->
    <div class="tab-pane" id="tab-filieres">
        <div class="clearfix" style="margin-bottom:10px">
            <div class="pull-right">
                <button class="btn btn-success btn-sm" onclick="openFiliereModal(0)">
                    <span class="glyphicon glyphicon-plus"></span> Ajouter
                </button>
            </div>
        </div>
        <table id="tblFilieres" class="table table-striped table-bordered table-hover">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Intitulé (Fr)</th>
                    <th>Intitulé (Ar)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="bodyFilieres"></tbody>
        </table>
    </div>

    <!-- Niveaux -->
    <div class="tab-pane" id="tab-niveaux">
        <div class="clearfix" style="margin-bottom:10px">
            <div class="pull-right">
                <button class="btn btn-success btn-sm" onclick="openNiveauModal(0)">
                    <span class="glyphicon glyphicon-plus"></span> Ajouter
                </button>
            </div>
        </div>
        <table id="tblNiveaux" class="table table-striped table-bordered table-hover">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Intitulé (Fr)</th>
                    <th>Abrégé</th>
                    <th>Filière</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="bodyNiveaux"></tbody>
        </table>
    </div>

    <!-- Journées -->
    <div class="tab-pane" id="tab-journees">
        <div class="clearfix" style="margin-bottom:10px">
            <div class="pull-right">
                <button class="btn btn-success btn-sm" onclick="openJourModal(0)">
                    <span class="glyphicon glyphicon-plus"></span> Ajouter
                </button>
            </div>
        </div>
        <table id="tblJournees" class="table table-striped table-bordered table-hover">
            <thead><tr><th>Date</th><th>Jour de la semaine</th><th>Actions</th></tr></thead>
            <tbody id="bodyJournees"></tbody>
        </table>
    </div>

    <!-- Centres -->
    <div class="tab-pane" id="tab-centres">
        <div class="clearfix" style="margin-bottom:10px">
            <div class="pull-right">
                <button class="btn btn-success btn-sm" onclick="openCentreModal(0)">
                    <span class="glyphicon glyphicon-plus"></span> Ajouter
                </button>
            </div>
        </div>
        <table id="tblCentres" class="table table-striped table-bordered table-hover">
            <thead><tr><th>Intitulé</th><th>Abrégé</th><th>Responsable</th><th>Localisation</th><th>Actions</th></tr></thead>
            <tbody id="bodyCentres"></tbody>
        </table>
    </div>

    <!-- Niveaux-Centres -->
    <div class="tab-pane" id="tab-niveaucentre">
        <div class="clearfix" style="margin-bottom:10px">
            <div class="pull-right">
                <button class="btn btn-success btn-sm" onclick="openNiveauCentreModal()">
                    <span class="glyphicon glyphicon-plus"></span> Ajouter
                </button>
            </div>
        </div>
        <table id="tblNiveauCentre" class="table table-striped table-bordered table-hover">
            <thead><tr><th>Niveau</th><th>Centre</th><th>Actions</th></tr></thead>
            <tbody id="bodyNiveauCentre"></tbody>
        </table>
    </div>

    <!-- Épreuves -->
    <div class="tab-pane" id="tab-epreuves">
        <div class="clearfix" style="margin-bottom:10px">
            <div class="pull-right">
                <button class="btn btn-success btn-sm" onclick="openEpreuveModal(0)">
                    <span class="glyphicon glyphicon-plus"></span> Ajouter
                </button>
            </div>
        </div>
        <table id="tblEpreuves" class="table table-striped table-bordered table-hover">
            <thead>
                <tr>
                    <th>Code</th><th>Intitulé</th><th>Nature</th><th>Type</th>
                    <th>Durée</th><th>Niveau</th><th>Séance</th><th>Nb Candidats</th><th>Actions</th>
                </tr>
            </thead>
            <tbody id="bodyEpreuves"></tbody>
        </table>
    </div>

    <!-- Crédits -->
    <div class="tab-pane" id="tab-credits">
        <div class="clearfix" style="margin-bottom:10px">
            <div class="pull-right">
                <button class="btn btn-success btn-sm" onclick="openCreditsModal(0)">
                    <span class="glyphicon glyphicon-plus"></span> Ajouter
                </button>
            </div>
        </div>
        <table id="tblCredits" class="table table-striped table-bordered table-hover">
            <thead>
                <tr><th>Épreuve</th><th>Niveau</th><th>Nb Candidats</th><th>Observation</th><th>Actions</th></tr>
            </thead>
            <tbody id="bodyCredits"></tbody>
        </table>
    </div>

</div>

<!-- Modal Séance -->
<div class="modal fade" id="modalSeance" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" id="seanceModalTitle">Séance</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="seanceId" />
                <div class="form-group">
                    <label>Désignation *</label>
                    <input type="text" class="form-control" id="seanceDesignation" />
                </div>
                <div class="form-group">
                    <label>Désignation abrégée</label>
                    <input type="text" class="form-control" id="seanceDesignationAbregee" />
                </div>
                <div class="form-group">
                    <label>Heure de début *</label>
                    <input type="time" class="form-control" id="seanceHeureDebut" />
                </div>
                <div id="seanceError" class="alert alert-danger" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button class="btn btn-primary" onclick="saveSeance()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Filière -->
<div class="modal fade" id="modalFiliere" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" id="filiereModalTitle">Filière</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="filiereId" />
                <div class="form-group">
                    <label>Code *</label>
                    <input type="text" class="form-control" id="filiereCode" />
                </div>
                <div class="form-group">
                    <label>Intitulé (Fr) *</label>
                    <input type="text" class="form-control" id="filiereIntituleFr" />
                </div>
                <div class="form-group">
                    <label>Intitulé (Ar)</label>
                    <input type="text" class="form-control" id="filiereIntituleAr" dir="rtl" />
                </div>
                <div id="filiereError" class="alert alert-danger" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button class="btn btn-primary" onclick="saveFiliere()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Niveau -->
<div class="modal fade" id="modalNiveau" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" id="niveauModalTitle">Niveau</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="niveauId" />
                <div class="form-group">
                    <label>Filière *</label>
                    <select class="form-control" id="niveauIdFiliere"></select>
                </div>
                <div class="form-group">
                    <label>Code *</label>
                    <input type="text" class="form-control" id="niveauCode" />
                </div>
                <div class="form-group">
                    <label>Intitulé (Fr) *</label>
                    <input type="text" class="form-control" id="niveauIntituleFr" />
                </div>
                <div class="form-group">
                    <label>Abrégé *</label>
                    <input type="text" class="form-control" id="niveauIntituleAbrg" />
                </div>
                <div class="form-group">
                    <label>Intitulé (Ar)</label>
                    <input type="text" class="form-control" id="niveauIntituleAr" dir="rtl" />
                </div>
                <div id="niveauError" class="alert alert-danger" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button class="btn btn-primary" onclick="saveNiveau()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Suppression -->
<div class="modal fade" id="modalDel" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Confirmer</h4>
            </div>
            <div class="modal-body"><p id="delMsg"></p></div>
            <div class="modal-footer">
                <button class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button class="btn btn-danger" id="btnDel">Supprimer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Jour -->
<div class="modal fade" id="modalJour" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" id="jourModalTitle">Journée</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="jourId" />
                <div class="form-group">
                    <label>Date *</label>
                    <input type="date" class="form-control" id="jourDate" />
                </div>
                <div id="jourError" class="alert alert-danger" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button class="btn btn-primary" onclick="saveJour()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Centre -->
<div class="modal fade" id="modalCentre" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" id="centreModalTitle">Centre</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="centreId" />
                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label>Intitulé *</label>
                            <input type="text" class="form-control" id="centreIntitule" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Abrégé</label>
                            <input type="text" class="form-control" id="centreIntituleAbrg" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Responsable</label>
                    <input type="text" class="form-control" id="centreResponsable" />
                </div>
                <div class="form-group">
                    <label>Localisation</label>
                    <input type="text" class="form-control" id="centreLocalisation" />
                </div>
                <div id="centreError" class="alert alert-danger" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button class="btn btn-primary" onclick="saveCentre()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Niveau-Centre -->
<div class="modal fade" id="modalNiveauCentre" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Affecter Niveau → Centre</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Niveau *</label>
                    <select class="form-control" id="ncNiveau"></select>
                </div>
                <div class="form-group">
                    <label>Centre *</label>
                    <select class="form-control" id="ncCentre"></select>
                </div>
                <div id="ncError" class="alert alert-danger" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button class="btn btn-primary" onclick="saveNiveauCentre()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Épreuve -->
<div class="modal fade" id="modalEpreuve" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" id="epreuveModalTitle">Épreuve</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="epreuveId" />
                <input type="hidden" id="epreuveHeureDebut" />
                <input type="hidden" id="epreuveHeureFin" />
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group"><label>Code</label><input type="text" class="form-control" id="epreuveCode" /></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label>Intitulé *</label><input type="text" class="form-control" id="epreuveIntitule" /></div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group"><label>Abrégé</label><input type="text" class="form-control" id="epreuveIntituleAbrg" /></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group"><label>Nature</label>
                            <select class="form-control" id="epreuveNature">
                                <option value="">--</option>
                                <option>Écrit</option><option>Oral</option><option>TP</option><option>Projet</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group"><label>Type</label>
                            <select class="form-control" id="epreuveType">
                                <option value="">--</option>
                                <option>Principal</option><option>Rattrapage</option><option>Commun</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Durée (HH:MM) *</label>
                            <input type="text" class="form-control" id="epreuveDuree" placeholder="01:30" pattern="^\d{2}:\d{2}$" />
                            <span class="help-block" style="font-size:11px">ex: 01:30 pour 1h30</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group"><label>Niveau *</label>
                            <select class="form-control" id="epreuveIdNiveau"></select>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group"><label>Nb Candidats</label>
                            <input type="number" class="form-control" id="epreuveNbCandidat" min="0" value="0" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label>Nb Enveloppes</label>
                            <input type="number" class="form-control" id="epreuveNbEnveloppes" min="0" value="0" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label>État dépôt sujet</label>
                            <select class="form-control" id="epreuveEtatDepot">
                                <option value="">--</option>
                                <option>Non déposé</option><option>Déposé</option><option>Distribué</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div id="epreuveError" class="alert alert-danger" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button class="btn btn-primary" onclick="saveEpreuve()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Crédits -->
<div class="modal fade" id="modalCredits" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" id="creditsModalTitle">Crédits</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="creditsId" />
                <div class="form-group"><label>Épreuve *</label>
                    <select class="form-control" id="creditsIdEpreuve"></select>
                </div>
                <div class="form-group"><label>Niveau *</label>
                    <select class="form-control" id="creditsIdNiveau"></select>
                </div>
                <div class="form-group"><label>Nb Candidats *</label>
                    <input type="number" class="form-control" id="creditsNbCandidat" min="0" value="0" />
                </div>
                <div class="form-group"><label>Observation</label>
                    <input type="text" class="form-control" id="creditsObservation" />
                </div>
                <div id="creditsError" class="alert alert-danger" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button class="btn btn-primary" onclick="saveCredits()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var sessionId = @Model.Id;
    var dtSeances, dtFilieres, dtNiveaux, dtJournees, dtCentres, dtNiveauCentre, dtEpreuves, dtCredits;
    var filieresList = [], niveauxList = [], centresList = [], seancesList = [], joursList = [], epreuvesList = [];

    $(function () {
        var dtOpts = { language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json' }, paging: false, searching: false, info: false };
        dtSeances      = $('#tblSeances').DataTable(dtOpts);
        dtFilieres     = $('#tblFilieres').DataTable(dtOpts);
        dtNiveaux      = $('#tblNiveaux').DataTable(dtOpts);
        dtJournees     = $('#tblJournees').DataTable(dtOpts);
        dtCentres      = $('#tblCentres').DataTable(dtOpts);
        dtNiveauCentre = $('#tblNiveauCentre').DataTable(dtOpts);
        dtEpreuves     = $('#tblEpreuves').DataTable(dtOpts);
        dtCredits      = $('#tblCredits').DataTable(dtOpts);

        loadSeances(); loadFilieres(); loadNiveaux();
        loadJournees(); loadCentres(); loadNiveauCentre();
        loadEpreuves(); loadCredits();
    });

    // ===== SÉANCES =====
    function loadSeances() {
        $.get('/SessionSeance/GetBySession?idSession=' + sessionId, function (data) {
            seancesList = data;
            dtSeances.clear();
            $('#nbSeances').text(data.length);
            data.forEach(function (s) {
                dtSeances.row.add([
                    s.designation, s.designationAbregee || '', s.heureDebut,
                    '<span class="table-actions">' +
                    '<button class="btn btn-xs btn-warning" onclick="openSeanceModal(' + s.id + ')"><span class="glyphicon glyphicon-pencil"></span></button> ' +
                    '<button class="btn btn-xs btn-danger" onclick="delItem(\'seance\',' + s.id + ',\'' + s.designation + '\')"><span class="glyphicon glyphicon-trash"></span></button>' +
                    '</span>'
                ]);
            });
