    // Additionne deux strings HH:MM → "HH:MM"
    function addHHMM(t1, t2) {
        var p1 = t1.split(':'), p2 = t2.split(':');
        var total = parseInt(p1[0]) * 60 + parseInt(p1[1]) + parseInt(p2[0]) * 60 + parseInt(p2[1]);
        return String(Math.floor(total / 60)).padStart(2, '0') + ':' + String(total % 60).padStart(2, '0');
    }

    function saveEpreuve() {
        var duree = $('#epreuveDuree').val().trim();
        if (!/^\d{2}:\d{2}$/.test(duree)) {
            $('#epreuveError').text('La durée doit être au format HH:MM (ex: 01:30)').show();
            return;
        }
        var heureDebut = $('#epreuveHeureDebut').val() || null;
        var heureFin = (heureDebut && /^\d{2}:\d{2}$/.test(heureDebut)) ? addHHMM(heureDebut, duree) : ($('#epreuveHeureFin').val() || null);

        var data = {
            id: parseInt($('#epreuveId').val()),
            idSession: sessionId,
            idNiveau: parseInt($('#epreuveIdNiveau').val()),
            code: $('#epreuveCode').val(),
            intitule: $('#epreuveIntitule').val(),
            intituleAbrg: $('#epreuveIntituleAbrg').val(),
            nature: $('#epreuveNature').val() || null,
            type: $('#epreuveType').val() || null,
            duree: duree,
            idSeance: null, idJour: null,
            heureDebut: heureDebut,
            heureFin: heureFin,
            nbCandidat: parseInt($('#epreuveNbCandidat').val()) || 0,
            nbEnveloppes: parseInt($('#epreuveNbEnveloppes').val()) || 0,
            etatDepotSujet: $('#epreuveEtatDepot').val() || null,
            nbEnveloppesADeposer: 0, totalNbEnveloppesDeposees: 0
        };
        $.ajax({ url: '/SessionEpreuve/Save', type: 'POST', contentType: 'application/json', data: JSON.stringify(data),
            success: function () { $('#modalEpreuve').modal('hide'); loadEpreuves(); loadCredits(); },
            error: function (xhr) { $('#epreuveError').text(xhr.responseJSON ? xhr.responseJSON.error : 'Erreur').show(); }
        });
    }

