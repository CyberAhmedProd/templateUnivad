@model List<ESP.Models.Session>
@{
    ViewData["Title"] = "Sessions";
}

<div class="page-header">
    <h3>
        <span class="glyphicon glyphicon-calendar"></span> Planification des examens
        <button class="btn btn-success btn-sm pull-right" onclick="openModal(0)">
            <span class="glyphicon glyphicon-plus"></span> Nouvelle session
        </button>
    </h3>
</div>

<div class="panel panel-default">
    <div class="panel-body">
        <table id="tblSessions" class="table table-striped table-bordered table-hover">
            <thead>
                <tr>
                    <th>Désignation</th>
                    <th>Année</th>
                    <th>Date début</th>
                    <th>Date fin</th>
                    <th>Type</th>
                    <th>Période</th>
                    <th>État</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.Designation</td>
                        <td>@s.Annee</td>
                        <td>@s.DateDebut.ToString("dd/MM/yyyy")</td>
                        <td>@s.DateFin.ToString("dd/MM/yyyy")</td>
                        <td>@s.Type</td>
                        <td>@s.Periode</td>
                        <td>
                            <span class="label @(s.Etat == "En Cours" ? "label-success" : "label-default")">@s.Etat</span>
                        </td>
                        <td class="table-actions">
                            <a href="/Session/Details/@s.Id" class="btn btn-xs btn-info" title="Détails">
                                <span class="glyphicon glyphicon-eye-open"></span>
                            </a>
                            <button class="btn btn-xs btn-warning" onclick="openModal(@s.Id)" title="Modifier">
                                <span class="glyphicon glyphicon-pencil"></span>
                            </button>
                            <button class="btn btn-xs btn-danger" onclick="confirmDelete(@s.Id, '@s.Designation')" title="Supprimer">
                                <span class="glyphicon glyphicon-trash"></span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Ajout/Modification -->
<div class="modal fade" id="modalSession" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" id="modalTitle">Session</h4>
            </div>
            <div class="modal-body">
                <form id="formSession">
                    <input type="hidden" id="sId" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Désignation *</label>
                                <input type="text" class="form-control" id="sDesignation" required />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Année *</label>
                                <input type="text" class="form-control" id="sAnnee" placeholder="2025-2026" required />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>État *</label>
                                <select class="form-control" id="sEtat">
                                    <option>En Cours</option>
                                    <option>Planifié</option>
                                    <option>Terminé</option>
                                    <option>Annulé</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Date début *</label>
                                <input type="date" class="form-control" id="sDateDebut" required />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Date fin *</label>
                                <input type="date" class="form-control" id="sDateFin" required />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Type *</label>
                                <select class="form-control" id="sType">
                                    <option>Examens</option>
                                    <option>Contrôles</option>
                                    <option>Rattrapage</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Période *</label>
                                <select class="form-control" id="sPeriode">
                                    <option>Semestre 1</option>
                                    <option>Semestre 2</option>
                                    <option>Annuel</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Unité</label>
                                <select class="form-control" id="sUnite">
                                    <option value="Heure">Heure</option>
                                    <option value="Minute">Minute</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Utiliser les groupes</label>
                                <select class="form-control" id="sUseGroupe">
                                    <option value="0">Non</option>
                                    <option value="1">Oui</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Observations</label>
                                <input type="text" class="form-control" id="sObservations" />
                            </div>
                        </div>
                    </div>
                    <div id="formError" class="alert alert-danger" style="display:none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" onclick="saveSession()">
                    <span class="glyphicon glyphicon-floppy-disk"></span> Enregistrer
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Confirmation Suppression -->
<div class="modal fade" id="modalDelete" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Confirmer la suppression</h4>
            </div>
            <div class="modal-body">
                <p>Supprimer la session <strong id="deleteLabel"></strong> ?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDelete">
                    <span class="glyphicon glyphicon-trash"></span> Supprimer
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var table;
    $(function () {
        table = $('#tblSessions').DataTable({
            language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json' },
            order: [[0, 'asc']]
        });
    });

    function openModal(id) {
        $('#formError').hide();
        $('#formSession')[0].reset();
        if (id === 0) {
            $('#modalTitle').text('Nouvelle session');
            $('#sId').val(0);
            $('#modalSession').modal('show');
        } else {
            $.get('/Session/GetById/' + id, function (s) {
                $('#modalTitle').text('Modifier la session');
                $('#sId').val(s.id);
                $('#sDesignation').val(s.designation);
                $('#sAnnee').val(s.annee);
                $('#sDateDebut').val(s.dateDebut.substring(0, 10));
                $('#sDateFin').val(s.dateFin.substring(0, 10));
                $('#sEtat').val(s.etat);
                $('#sType').val(s.type);
                $('#sPeriode').val(s.periode);
                $('#sUnite').val(s.unite);
                $('#sUseGroupe').val(s.useGroupe);
                $('#sObservations').val(s.observations);
                $('#modalSession').modal('show');
            });
        }
    }

    function saveSession() {
        var data = {
            id: parseInt($('#sId').val()),
            designation: $('#sDesignation').val(),
            annee: $('#sAnnee').val(),
            dateDebut: $('#sDateDebut').val(),
            dateFin: $('#sDateFin').val(),
            etat: $('#sEtat').val(),
            type: $('#sType').val(),
            periode: $('#sPeriode').val(),
            unite: $('#sUnite').val(),
            useGroupe: parseInt($('#sUseGroupe').val()),
            observations: $('#sObservations').val(),
            idOrganisation: 1,
            intervalleMinOccupationSalle: 0,
            intervalleMinSurveillancesSucc: 0
        };
        $.ajax({
            url: '/Session/Save',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function () {
                $('#modalSession').modal('hide');
                location.reload();
            },
            error: function (xhr) {
                var err = xhr.responseJSON ? xhr.responseJSON.error : 'Erreur serveur';
                $('#formError').text(err).show();
            }
        });
    }

    function confirmDelete(id, label) {
        $('#deleteLabel').text(label);
        $('#btnConfirmDelete').off('click').on('click', function () {
            $.post('/Session/Delete?id=' + id, function () {
                $('#modalDelete').modal('hide');
                location.reload();
            });
        });
        $('#modalDelete').modal('show');
    }
</script>
}
